<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bookings - EpiCuts Admin</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root { --gold: #d4a843; --gold-light: #e8c36a; --dark: #0a0a0a; --darker: #050505; --card: #111; --card-hover: #1a1a1a; --text: #e0e0e0; --text-muted: #999; --border: #1e1e1e; --red: #c0392b; --green: #27ae60; }
body { font-family: 'Inter', sans-serif; background: var(--darker); color: var(--text); }
a { color: var(--gold); text-decoration: none; }
a:hover { color: var(--gold-light); }
.sidebar { position: fixed; left: 0; top: 0; width: 240px; height: 100vh; background: var(--card); border-right: 2px solid var(--border); padding: 32px 24px; display: flex; flex-direction: column; }
.sidebar h2 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; color: #fff; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 32px; }
.sidebar h2 span { color: var(--gold); }
.sidebar nav { display: flex; flex-direction: column; gap: 4px; }
.sidebar nav a { padding: 12px 16px; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; border-left: 3px solid transparent; transition: all 0.3s; }
.sidebar nav a:hover, .sidebar nav a.active { color: var(--gold); border-left-color: var(--gold); background: rgba(212,168,67,0.05); }
.sidebar .logout { margin-top: auto; padding-top: 24px; border-top: 1px solid var(--border); }
.main { margin-left: 240px; padding: 32px 40px; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
.top-bar h1 { font-family: 'Oswald', sans-serif; font-size: 1.8rem; color: #fff; text-transform: uppercase; letter-spacing: 2px; }
.filters { display: flex; gap: 8px; }
.filters a { padding: 8px 20px; border: 1px solid var(--border); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s; }
.filters a:hover, .filters a.active { border-color: var(--gold); color: var(--gold); }
table { width: 100%; border-collapse: collapse; background: var(--card); border: 1px solid var(--border); }
th { background: var(--dark); padding: 12px 16px; text-align: left; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); border-bottom: 2px solid var(--border); }
td { padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 0.85rem; }
tr:hover td { background: var(--card-hover); }
.status { display: inline-block; padding: 4px 12px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
.status.pending { background: rgba(212,168,67,0.2); color: var(--gold); }
.status.confirmed { background: rgba(39,174,96,0.2); color: var(--green); }
.status.cancelled { background: rgba(192,57,43,0.2); color: var(--red); }
.btn-sm { padding: 6px 14px; font-family: 'Oswald', sans-serif; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; border: none; cursor: pointer; transition: all 0.3s; display: inline-block; }
.btn-confirm { background: var(--green); color: #fff; }
.btn-confirm:hover { background: #2ecc71; }
.btn-cancel { background: var(--red); color: #fff; }
.btn-cancel:hover { background: #e74c3c; }
.btn-delete { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
.btn-delete:hover { color: var(--red); border-color: var(--red); }
.actions { display: flex; gap: 6px; align-items: center; }
.empty { color: var(--text-muted); text-align: center; padding: 40px; font-size: 0.9rem; }
.footer { text-align: center; padding: 40px 0 20px; color: var(--text-muted); font-size: 0.8rem; }
</style>
</head>
<body>
<aside class="sidebar">
  <h2>EPI <span>CUTS</span></h2>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/bookings" class="active">Bookings</a>
    <a href="/admin/contacts">Messages</a>
    <a href="/admin/gallery">Gallery</a>
    <a href="/admin/content">Content</a>
    <a href="/admin/email">Email</a>
  </nav>
  <div class="logout"><a href="/admin/logout">Logout</a></div>
</aside>
<div class="main">
  <div class="top-bar">
    <h1>Bookings</h1>
    <div class="filters">
      <a href="/admin/bookings" class="<%= currentStatus === '' ? 'active' : '' %>">All</a>
      <a href="/admin/bookings?status=pending" class="<%= currentStatus === 'pending' ? 'active' : '' %>">Pending</a>
      <a href="/admin/bookings?status=confirmed" class="<%= currentStatus === 'confirmed' ? 'active' : '' %>">Confirmed</a>
      <a href="/admin/bookings?status=cancelled" class="<%= currentStatus === 'cancelled' ? 'active' : '' %>">Cancelled</a>
    </div>
  </div>

  <% if (bookings.length) { %>
  <table>
    <tr><th>Name</th><th>Email</th><th>Phone</th><th>Service</th><th>Date</th><th>Time</th><th>Status</th><th>Actions</th></tr>
    <% bookings.forEach(b => { %>
    <tr>
      <td><%= b.name %></td>
      <td><%= b.email %></td>
      <td><%= b.phone %></td>
      <td><%= b.service %></td>
      <td><%= b.date %></td>
      <td><%= b.time %></td>
      <td><span class="status <%= b.status %>"><%= b.status %></span></td>
      <td>
        <div class="actions">
          <% if (b.status === 'pending') { %>
          <form method="POST" action="/admin/bookings/<%= b.id %>/status" style="display:inline">
            <input type="hidden" name="status" value="confirmed">
            <button type="submit" class="btn-sm btn-confirm">Confirm</button>
          </form>
          <form method="POST" action="/admin/bookings/<%= b.id %>/status" style="display:inline">
            <input type="hidden" name="status" value="cancelled">
            <button type="submit" class="btn-sm btn-cancel">Cancel</button>
          </form>
          <% } %>
          <form method="POST" action="/admin/bookings/<%= b.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this booking?')">
            <button type="submit" class="btn-sm btn-delete">Delete</button>
          </form>
        </div>
      </td>
    </tr>
    <% if (b.message) { %><tr><td colspan="8" style="font-size:0.8rem;color:var(--text-muted);padding-top:0">Note: <%= b.message %></td></tr><% } %>
    <% }) %>
  </table>
  <% } else { %><div class="empty">No bookings found.</div><% } %>

  <div class="footer">&copy; 2026 EpiCuts Admin</div>
</div>
</body>
</html>
