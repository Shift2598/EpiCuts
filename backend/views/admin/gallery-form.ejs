<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= image ? 'Edit' : 'Add' %> Gallery Image - EpiCuts Admin</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root { --gold: #d4a843; --gold-light: #e8c36a; --dark: #0a0a0a; --darker: #050505; --card: #111; --card-hover: #1a1a1a; --text: #e0e0e0; --text-muted: #999; --border: #1e1e1e; }
body { font-family: 'Inter', sans-serif; background: var(--darker); color: var(--text); }
a { color: var(--gold); text-decoration: none; }
.sidebar { position: fixed; left: 0; top: 0; width: 240px; height: 100vh; background: var(--card); border-right: 2px solid var(--border); padding: 32px 24px; display: flex; flex-direction: column; }
.sidebar h2 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; color: #fff; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 32px; }
.sidebar h2 span { color: var(--gold); }
.sidebar nav a { display: block; padding: 12px 16px; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; border-left: 3px solid transparent; transition: all 0.3s; }
.sidebar nav a:hover, .sidebar nav a.active { color: var(--gold); border-left-color: var(--gold); background: rgba(212,168,67,0.05); }
.sidebar .logout { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); }
.main { margin-left: 240px; padding: 32px 40px; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
.top-bar h1 { font-family: 'Oswald', sans-serif; font-size: 1.8rem; color: #fff; text-transform: uppercase; letter-spacing: 2px; }
.back { color: var(--text-muted); font-size: 0.85rem; }
.back:hover { color: var(--gold); }
.form-card { background: var(--card); border: 1px solid var(--border); padding: 32px; max-width: 600px; }
.form-group { margin-bottom: 24px; }
.form-group label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); margin-bottom: 8px; font-weight: 600; }
.form-group input, .form-group textarea { width: 100%; padding: 12px 16px; background: var(--dark); border: 1px solid var(--border); color: #fff; font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none; }
.form-group input:focus, .form-group textarea:focus { border-color: var(--gold); }
.form-group textarea { min-height: 80px; resize: vertical; }
.form-group .hint { font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; }
.form-group .current-img { display: block; margin-top: 8px; max-width: 200px; border: 1px solid var(--border); }
.form-row { display: flex; gap: 16px; }
.form-row .form-group { flex: 1; }
.btn-row { display: flex; gap: 12px; margin-top: 32px; }
.btn { padding: 14px 32px; font-family: 'Oswald', sans-serif; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; text-decoration: none; display: inline-block; }
.btn-primary { background: var(--gold); color: #000; }
.btn-primary:hover { background: var(--gold-light); }
.btn-secondary { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
.btn-secondary:hover { border-color: var(--text); color: var(--text); }
.error { background: rgba(192,57,43,0.2); border: 1px solid #c0392b; color: #c0392b; padding: 12px 16px; margin-bottom: 24px; font-size: 0.85rem; }
</style>
</head>
<body>
<aside class="sidebar">
  <h2>EPI <span>CUTS</span></h2>
  <nav>
    <a href="/admin">Dashboard</a>
    <a href="/admin/gallery" class="active">Gallery</a>
    <a href="/admin/content">Content</a>
    <a href="/admin/email">Email</a>
  </nav>
  <div class="logout"><a href="/admin/logout">Logout</a></div>
</aside>
<div class="main">
  <div class="top-bar">
    <h1><%= image ? 'Edit Image' : 'Add Image' %></h1>
    <a href="/admin/gallery" class="back">&larr; Back to Gallery</a>
  </div>

  <% if (locals.error) { %><div class="error"><%= error %></div><% } %>

  <div class="form-card">
    <form method="POST" action="<%= image ? '/admin/gallery/edit/' + image.id : '/admin/gallery/add' %>" enctype="multipart/form-data">
      <div class="form-group">
        <label>Title *</label>
        <input type="text" name="title" value="<%= image ? image.title : '' %>" required>
      </div>
      <div class="form-group">
        <label>Subtitle / Overlay Text</label>
        <input type="text" name="subtitle" value="<%= image ? image.subtitle : '' %>">
        <div class="hint">Short description shown on hover (e.g. "crowd favorite")</div>
      </div>
      <div class="form-group">
        <label>Image URL</label>
        <input type="text" name="image_url" value="<%= image ? '' : '' %>" placeholder="https://example.com/image.jpg">
        <div class="hint">Paste a URL or upload a file below</div>
      </div>
      <div class="form-group">
        <label>Or Upload File</label>
        <input type="file" name="image" accept="image/*">
        <% if (image) { %>
          <img src="<%= image.image_url %>" class="current-img" alt="Current">
        <% } %>
      </div>
      <div class="btn-row">
        <button type="submit" class="btn btn-primary"><%= image ? 'Save Changes' : 'Add Image' %></button>
        <a href="/admin/gallery" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
</body>
</html>
